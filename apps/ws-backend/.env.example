# WebSocket backend (ws) environment variables.
# On Railway, set these in the service's Variables tab. PORT is injected by
# Railway automatically — do NOT set it yourself.

# Neon PostgreSQL connection string (same value as the HTTP backend).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&channel_binding=require

# JWT signing secret. MUST be identical to the HTTP backend's JWT_SECRET, or
# tokens issued at sign-in will fail verification on the socket.
JWT_SECRET=change-me-to-a-long-random-string

# Set to "production" in production.
NODE_ENV=development
