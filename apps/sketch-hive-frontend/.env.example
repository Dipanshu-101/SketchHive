# Frontend (Next.js) environment variables.
# Copy to `.env.local` for local development. On Vercel, set these in
# Project Settings -> Environment Variables.
#
# NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time and are
# PUBLIC. Never put secrets here.

# Base URL of the HTTP backend (Railway). Use https:// in production.
NEXT_PUBLIC_HTTP_URL=http://localhost:3001

# Base URL of the WebSocket backend (Railway). Use wss:// in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8080
