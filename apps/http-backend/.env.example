# HTTP backend (Express) environment variables.
# On Railway, set these in the service's Variables tab. PORT is injected by
# Railway automatically — do NOT set it yourself.

# Neon PostgreSQL connection string (same value used by the WS backend and by
# Prisma migrations). Keep sslmode=verify-full for a verified TLS connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&channel_binding=require

# Secret used to sign/verify JWTs. MUST be identical on the HTTP and WS backends.
# Use a long, random value in production.
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins for CORS (your Vercel URL).
# e.g. https://sketchhive.vercel.app
FRONTEND_URL=http://localhost:3000

# Set to "production" in production. Enables strict env validation (JWT_SECRET
# required) and production-safe behavior.
NODE_ENV=development
