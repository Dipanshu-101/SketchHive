# Database package environment.
# Copy to `.env` for local development and for running Prisma migrations from
# your machine. This file is the source of DATABASE_URL for:
#   - the Prisma CLI (migrate deploy / migrate dev), via prisma.config.ts
#   - the runtime Prisma client (packages/db/src/index.ts), as a local fallback
#
# In production the backends receive DATABASE_URL from Railway service variables,
# so this file is NOT needed there.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&channel_binding=require"
