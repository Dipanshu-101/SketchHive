generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  photo     String?
  room      Room[]
  chats     Chat[]
  messages  Message[]
}

model Room {
  id        Int   @id @default(autoincrement())
  slug     String   @unique
  createdAt DateTime @default(now())
  adminId   String
  admin    User     @relation(fields: [adminId], references: [id])
  chats     Chat[]
  messages  Message[]
}

// NOTE: `Chat` is the whiteboard's persistence table. Despite the name, each
// row stores ONE drawing operation (a serialized shape) — see ws-backend's
// persistChatOp and draw/net.ts. It is NOT the collaboration chat. Leaving it
// exactly as-is keeps drawing sync untouched.
model Chat {
  id        Int   @id @default(autoincrement())
  message   String
  userId    String
  roomId    Int
  room     Room     @relation(fields: [roomId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

// `Message` is the real, human-to-human room chat (Version 1).
//
// senderName is denormalized on purpose: it is captured at write time so the
// chat history renders correctly even if the user later changes their display
// name, and so reads never need to join User. The `user` relation is still kept
// for integrity and future features (mentions, profiles).
//
// Indexed by (roomId, createdAt) because the only read pattern is "the latest N
// messages for a room, in chronological order".
model Message {
  id         String   @id @default(uuid())
  roomId     Int
  senderId   String
  senderName String
  message    String
  createdAt  DateTime @default(now())

  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([roomId, createdAt])
}